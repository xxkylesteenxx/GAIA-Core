# GAIA PREEMPT_RT kernel configuration fragment
# Apply with: scripts/kconfig/merge_config.sh .config platform/kernel/configs/gaia-rt.config
#
# Minimum kernel version: 6.6
# Target: x86_64 (adapt for ARM64 as needed)

# ============================================================
# Real-time preemption
# ============================================================
CONFIG_PREEMPT_RT=y
CONFIG_PREEMPT=y
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_NO_HZ_FULL=y
CONFIG_RCU_NOCB_CPU=y

# ============================================================
# CPU isolation and IRQ threading
# ============================================================
CONFIG_CPU_ISOLATION=y
CONFIG_IRQ_FORCED_THREADING=y
CONFIG_THREAD_INFO_IN_TASK=y

# ============================================================
# sched_ext BPF scheduler
# ============================================================
CONFIG_SCHED_CLASS_EXT=y
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_LSM=y
CONFIG_HAVE_EBPF_JIT=y

# ============================================================
# cgroup v2
# ============================================================
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_SCHED=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_UNIFIED_CGROUP_HIERARCHY=y

# ============================================================
# Memory
# ============================================================
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_NUMA=y
CONFIG_NUMA_BALANCING=y
CONFIG_MEMORY_HOTPLUG=y

# ============================================================
# LSM stack
# ============================================================
CONFIG_SECURITY=y
CONFIG_SECURITY_STACKING=y
CONFIG_LSM="lockdown,yama,loadpin,safesetid,selinux,smack,tomoyo,apparmor,bpf"
# guardian_lsm is loaded as a stackable module on top
CONFIG_SECURITY_WRITABLE_HOOKS=y
CONFIG_SECURITY_PATH=y
CONFIG_SECURITYFS=y

# ============================================================
# Performance and tracing
# ============================================================
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_IRQSOFF_TRACER=y
CONFIG_PREEMPT_TRACER=y
CONFIG_SCHED_TRACER=y
CONFIG_HIST_TRIGGERS=y
CONFIG_PERF_EVENTS=y
CONFIG_PERF_COUNTERS=y

# ============================================================
# Disable non-RT-safe features
# ============================================================
# CONFIG_CPU_FREQ_GOV_ONDEMAND is not set
# CONFIG_CPU_FREQ_GOV_CONSERVATIVE is not set
# CONFIG_NUMA_BALANCING_DEFAULT_ENABLED is not set
